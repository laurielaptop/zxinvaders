; Video primitives for ZX Spectrum 48K
; Constants defined in constants.z80

Video_Init:
    call Video_ClearBitmap
    call Video_ClearAttributes
    xor a
    out (254), a
    ret

Video_ClearBitmap:
    ld hl, SCREEN_PIXELS
    ld de, SCREEN_PIXELS + 1
    ld bc, 6911
    ld (hl), 0
    ldir
    ret

Video_ClearAttributes:
    ld hl, SCREEN_ATTRS
    ld de, SCREEN_ATTRS + 1
    ld bc, 767
    ld (hl), 7
    ldir
    ret
