; Timing helper for predictable development frame pacing.

Timing_WaitFrame:
    ; Temporary busy-wait. Replaced later with IRQ-based cadence.
    ld bc, 50000
Timing_WaitFrame_Loop:
    dec bc
    ld a, b
    or c
    jr nz, Timing_WaitFrame_Loop
    ret
Timing_WaitShort:
    ; Much shorter wait for testing (avoids long busy loops)
    ld bc, 5000
Timing_WaitShort_Loop:
    dec bc
    ld a, b
    or c
    jr nz, Timing_WaitShort_Loop
    ret